# Visual Studio configuration folders
.vs/
.idea/
.vscode/

# Build output
bin/
obj/

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# Artifacts
artifacts/

# Project lock files (NuGet)
project.lock.json
project.fragment.lock.json

